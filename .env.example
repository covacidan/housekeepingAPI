# housekeepingAPI/.env.example
#
# Used only when running api + ui standalone (outside of Terraform).
# When running the full stack via Terraform, all secrets come from Vault.
#
# Copy to .env and fill in values, or export as environment variables.

# PostgreSQL — provisioned by Terraform (housekeepingTF)
DB_NAME=housekeeping2
DB_USER=housekeeping2
DB_PASSWORD=change_me

# Keycloak — provisioned by Terraform (housekeepingTF)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Vault AppRole (output by `terraform output` after `make apply`)
# Leave empty to fall back to static DB_USER / DB_PASSWORD above
VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
